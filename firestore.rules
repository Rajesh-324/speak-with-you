rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for common checks
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "gunagantirajesh7@gmail.com";
    }

    // Users collection (includes private profiles and /friendHistory subcollection)
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Progress collection (stores private studyPlans, weaknesses, and progress tracking)
    match /progress/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Public Leaderboard collection — authenticated reads, owner writes only
    // Writes are strictly restricted to public-safe fields to prevent data leaking
    match /leaderboard/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId)
        && request.resource.data.keys().hasAll(['uid', 'displayName', 'photoURL', 'xp', 'streak'])
        && request.resource.data.keys().hasOnly(['uid', 'displayName', 'photoURL', 'xp', 'streak']);
    }

    // Public referral codes mapping: code -> { uid }
    match /referralCodes/{code} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }

    // Referral claims: claimId (refereeUid) -> { refereeUid, referrerUid, code, processed }
    // Enforces single-claim per referee, self-referral prevention, and restricted field updates
    match /referrals/{claimId} {
      allow read: if isAuthenticated() && (resource.data.refereeUid == request.auth.uid || resource.data.referrerUid == request.auth.uid);
      allow create: if isOwner(claimId)
        && request.resource.data.refereeUid == request.auth.uid 
        && request.resource.data.referrerUid != request.auth.uid
        && request.resource.data.processed == false;
      allow update: if isAuthenticated() 
        && resource.data.referrerUid == request.auth.uid
        && request.resource.data.processed == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['processed']);
    }

    // Interviews collection — owner or admin only
    match /interviews/{interviewId} {
      allow read, update, delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
